                "exec": [
                  "pm.test('状态码 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('搜索结果包含 iPhone', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var hasMatch = jsonData.data.some(function(item) {",
                  "        return item.name && item.name.includes('iPhone');",
                  "    });",
                  "    pm.expect(hasMatch).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
