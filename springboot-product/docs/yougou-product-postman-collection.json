{
  "info": {
    "name": "优购商城 - 商品接口测试集",
    "description": "基于 RESTful 规范的商品管理接口测试，包含正常场景、参数校验、异常处理全覆盖测试用例。\n\n测试环境：\n- 本地开发环境： http://localhost:8080\n\n接口列表：\n- POST   /products/add       新增商品\n- PUT    /products/update    更新商品\n- DELETE /products/delete    删除商品\n- DELETE /products/delete/batch 批量删除商品\n- GET    /products/query     分页查询商品列表\n- GET    /products/{id}      查询单个商品详情",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "createdProductId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. 新增商品（POST /products/add）",
      "item": [
        {
          "name": "【TC-001】正常创建商品 - 必填参数完整",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('响应 code=200', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "});",
                  "pm.test('响应 msg=操作成功', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.msg).to.eql('操作成功');",
                  "});",
                  "pm.test('返回商品 ID', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.collectionVariables.set('createdProductId', jsonData.data.id);",
                  "});",
                  "pm.test('响应时间 < 500ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Apple iPhone 16 Pro Max 512GB\",\n    \"category\": \"手机数码\",\n    \"price\": 12999.00,\n    \"stock\": 100,\n    \"description\": \"全新A18仿生芯片，6.9英寸超视网膜XDR显示屏，钛金属边框设计\",\n    \"imageUrl\": \"https://example.com/iphone16.jpg\",\n    \"status\": 1,\n    \"sales\": 0,\n    \"rating\": 5.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/add",
              "host": ["{{baseUrl}}"],
              "path": ["products", "add"]
            }
          }
        },
        {
          "name": "【TC-002】商品名称为空 - 触发参数校验",
