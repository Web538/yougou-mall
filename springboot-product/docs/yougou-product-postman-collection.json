    {
      "name": "4. 查询商品（GET /products/query）",
      "item": [
        {
          "name": "【TC-015】默认分页查询 - 返回分页数据",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('响应 code=200', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "});",
                  "pm.test('data 是数组', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "pm.test('包含分页信息', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.page).to.have.property('current');",
                  "    pm.expect(jsonData.page).to.have.property('size');",
                  "    pm.expect(jsonData.page).to.have.property('total');",
                  "    pm.expect(jsonData.page).to.have.property('pages');",
                  "});",
                  "pm.test('total >= 0', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.page.total).to.be.at.least(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/query",
              "host": ["{{baseUrl}}"],
              "path": ["products", "query"]
            }
          }
        },
        {
          "name": "【TC-016】关键词搜索 - 按名称模糊查询",
          "event": [
            {
              "listen": "test",
