          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('价格升序排列', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var prices = jsonData.data.map(function(item) { return item.price; });",
                  "    for (var i = 0; i < prices.length - 1; i++) {",
                  "        pm.expect(prices[i]).to.be.at.most(prices[i + 1]);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/query?sortBy=price&sortOrder=asc",
              "host": ["{{baseUrl}}"],
              "path": ["products", "query"],
              "query": [
                {
                  "key": "sortBy",
                  "value": "price"
                },
                {
                  "key": "sortOrder",
                  "value": "asc"
                }
              ]
            }
