                  "    var jsonData = pm.response.json();",
                  "    var sales = jsonData.data.map(function(item) { return item.sales; });",
                  "    for (var i = 0; i < sales.length - 1; i++) {",
                  "        pm.expect(sales[i]).to.be.at.least(sales[i + 1]);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/query?sortBy=sales&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["products", "query"],
              "query": [
                {
                  "key": "sortBy",
                  "value": "sales"
