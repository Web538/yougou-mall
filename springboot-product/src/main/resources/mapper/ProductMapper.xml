<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yougou.product.mapper.ProductMapper">

    <!-- ========== 分页查询商品 ========== -->
    <select id="selectProductPage" resultType="com.yougou.product.entity.Product">
        SELECT
            id,
            name,
            category,
            price,
            stock,
            description,
            image_url AS imageUrl,
            status,
            sales,
            rating,
            create_time AS createTime,
            update_time AS updateTime
        FROM t_product
        WHERE deleted = 0
        <!-- 关键词搜索：名称 或 描述 -->
        <if test="keyword != null and keyword != ''">
            AND (
                name LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%')
            )
        </if>
        <!-- 分类精确匹配 -->
        <if test="category != null and category != ''">
            AND category = #{category}
        </if>
        <!-- 状态过滤 -->
        <if test="status != null">
            AND status = #{status}
        </if>
        <!-- 动态排序 -->
        ORDER BY
        <choose>
            <when test="sortBy == 'price'">price</when>
            <when test="sortBy == 'sales'">sales</when>
            <when test="sortBy == 'rating'">rating</when>
            <when test="sortBy == 'stock'">stock</when>
            <otherwise>create_time</otherwise>
        </choose>
        <choose>
            <when test="sortOrder == 'asc'">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>

    <!-- ========== 检查商品名称是否存在（排除自身）========== -->
    <select id="countByNameExcludingId" resultType="int">
        SELECT COUNT(*)
        FROM t_product
        WHERE deleted = 0
          AND name = #{name}
        <if test="excludeId != null">
          AND id != #{excludeId}
        </if>
    </select>

</mapper>
